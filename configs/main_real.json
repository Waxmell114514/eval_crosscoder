{
  "experiment_name": "main_citation_abstention_real",
  "backend": "huggingface",
  "runs_root": "runs",
  "task": {
    "name": "citation_abstention",
    "phase": "main",
    "templates": [
      "evidence_first",
      "review_style",
      "strict_citation",
      "heldout_forensic",
      "heldout_brief"
    ],
    "held_out_templates": [
      "heldout_forensic",
      "heldout_brief"
    ],
    "split_strategy": {
      "train_templates": [
        "evidence_first",
        "review_style",
        "strict_citation"
      ],
      "held_out_templates": [
        "heldout_forensic",
        "heldout_brief"
      ]
    },
    "label_field": "behavior_label",
    "scoring": {
      "target_metric": "target_success"
    },
    "schema": {
      "required_fields": [
        "Answer",
        "Evidence"
      ]
    }
  },
  "model": {
    "base_model_name_or_path": "google/gemma-2-2b-it",
    "tokenizer_name_or_path": "google/gemma-2-2b-it",
    "trust_remote_code": false,
    "torch_dtype": "bfloat16",
    "device": "cuda",
    "max_seq_length": 768,
    "max_new_tokens": 128,
    "inference_batch_size": 2
  },
  "data": {
    "source": "generated",
    "seed": 29,
    "train_size": 180,
    "val_size": 72,
    "test_size": 72,
    "generic_unpaired_size": 40,
    "train_template_families": [
      "evidence_first",
      "review_style",
      "strict_citation"
    ],
    "held_out_template_families": [
      "heldout_forensic",
      "heldout_brief"
    ]
  },
  "lora": {
    "seed": 21,
    "rank": 16,
    "alpha": 32,
    "dropout": 0.05,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "num_epochs": 2,
    "batch_size": 1,
    "gradient_accumulation_steps": 8,
    "learning_rate": 0.00015,
    "weight_decay": 0.0,
    "max_grad_norm": 1.0,
    "gradient_checkpointing": true
  },
  "cache": {
    "layers": [],
    "token_strategy": "final_token",
    "matched_ratio": 1.0,
    "unpaired_ratio": 0.2,
    "serialization": "npz"
  },
  "methods": {
    "enabled": [
      "raw_diff",
      "mean_diff",
      "pca",
      "behavior_probe",
      "standard_crosscoder",
      "batch_topk_crosscoder",
      "dfc",
      "delta_crosscoder",
      "single_model_sae"
    ],
    "post_gate_methods": [],
    "always_include_methods": [],
    "training": {
      "latent_dim": 16,
      "epochs": 24,
      "lr": 0.01,
      "sparsity_weight": 0.001,
      "batch_topk": 4,
      "shared_fraction": 0.33
    }
  },
  "evaluation": {
    "phase_gate": {
      "unsupported_abstention_improvement": 0.2,
      "borderline_fabrication_reduction": 0.15
    },
    "raw_probe_auroc_threshold": 0.75,
    "feature_advantage_threshold": 0.05
  },
  "causal": {
    "top_k_values": [
      5,
      20
    ],
    "steer_scale": 0.8,
    "ablate_scale": 0.8
  },
  "reporting": {}
}
